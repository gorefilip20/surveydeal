# ══════════════════════════════════════════════
# SURVEYDEAL FRONTEND — PRODUCTION CONFIGURATION
# Copy this to .env.local on your Hostinger VPS
# ══════════════════════════════════════════════

NEXT_PUBLIC_ESCROW_CONTRACT=""
NEXT_PUBLIC_API_URL="https://yourdomain.com/api"
NEXT_PUBLIC_WALLETCONNECT_ID="04b9e6e5c9184e0ab1ef6c1b6d4ecb29"

# Per-chain contract addresses (leave blank if not deployed)
NEXT_PUBLIC_CONTRACT_BSC=""
NEXT_PUBLIC_CONTRACT_ETH=""
NEXT_PUBLIC_CONTRACT_ARB=""
NEXT_PUBLIC_CONTRACT_BASE=""
NEXT_PUBLIC_CONTRACT_POLYGON=""
NEXT_PUBLIC_CONTRACT_OP=""

# Database — needed for Prisma generate at build time
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/surveydeal?schema=public&sslmode=require"
