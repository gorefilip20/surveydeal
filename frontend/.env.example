# ══════════════════════════════════════════════
#  SURVEYDEAL FRONTEND — ENVIRONMENT VARIABLES
# ══════════════════════════════════════════════

# Escrow contract address (output from deploy script)
NEXT_PUBLIC_ESCROW_CONTRACT="0x5FbDB2315678afecb367f032d93F642f64180aa3"

# Backend API URL
NEXT_PUBLIC_API_URL="http://localhost:5000/api"

# WalletConnect Project ID (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=""

# Alchemy API key (optional, for mainnet/arbitrum RPCs)
NEXT_PUBLIC_ALCHEMY_API_KEY=""

# Database (used by Prisma generate only — frontend doesn't query directly)
DATABASE_URL="postgresql://user:password@localhost:5432/surveydeal?schema=public"
