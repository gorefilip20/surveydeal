# ══════════════════════════════════════════════
#  SURVEYDEAL BACKEND — ENVIRONMENT VARIABLES
# ══════════════════════════════════════════════

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/surveydeal?schema=public"

# JWT secret for auth tokens (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET="CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING"

# Admin wallet private key (for on-chain admin operations)
# For local dev, Hardhat Account #0:
ADMIN_PRIVATE_KEY="0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80"

# Admin wallet address (for seeding)
ADMIN_WALLET="0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266"

# Contract address (output from deploy script)
CONTRACT_ADDRESS="0x5FbDB2315678afecb367f032d93F642f64180aa3"

# RPC URL
RPC_URL="http://127.0.0.1:8545"

# Chain ID
CHAIN_ID="31337"

# Server
BACKEND_PORT="5000"
FRONTEND_URL="http://localhost:3000"
NODE_ENV="development"

# Blockchain listener (set to "false" to disable)
ENABLE_BLOCKCHAIN_LISTENER="true"
