# ══════════════════════════════════════════════
# SURVEYDEAL BACKEND — PRODUCTION CONFIGURATION
# Copy this to .env on your Hostinger VPS
# ══════════════════════════════════════════════

# ── Database ──────────────────────────────────
# Use your Hostinger MySQL or external PostgreSQL (Neon, Supabase, Railway)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/surveydeal?schema=public&sslmode=require"

# ── Auth ──────────────────────────────────────
# IMPORTANT: Generate a fresh 64-char hex secret for production
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="REPLACE_WITH_RANDOM_64_HEX_SECRET"

# ── Smart Contract ────────────────────────────
# Set to your deployed contract address on mainnet/testnet
CONTRACT_ADDRESS=""
# Set to the chain where your contract is deployed
CHAIN_ID="56"

# ── Server ────────────────────────────────────
BACKEND_PORT="5000"
FRONTEND_URL="https://yourdomain.com"
NODE_ENV="production"

# ── Blockchain Listener ──────────────────────
# In production with deposit-transfer workflow, set to "true"
# The system will skip local Hardhat events and only run deposit polling
ENABLE_BLOCKCHAIN_LISTENER="true"
# Only needed if you deploy a contract to a live chain
RPC_URL=""

# ── Multi-Chain RPC Endpoints ─────────────────
# Free public RPCs are rate-limited. For production, use premium RPCs:
# Alchemy, Infura, QuickNode, Ankr, or BlastAPI
RPC_BSC="https://bsc-dataseed1.binance.org"
RPC_ETH="https://eth.llamarpc.com"
RPC_ARB="https://arb1.arbitrum.io/rpc"
RPC_BASE="https://mainnet.base.org"
RPC_POLYGON="https://polygon-rpc.com"
RPC_OP="https://mainnet.optimism.io"

# ── Admin ─────────────────────────────────────
ADMIN_WALLET="0xYOUR_ADMIN_WALLET_ADDRESS"
ADMIN_EMAIL="admin@yourdomain.com"
