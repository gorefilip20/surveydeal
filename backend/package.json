{
  "name": "surveydeal-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Surveydeal — Admin Backend & Blockchain Event Listener",
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "dev:local": "concurrently -k -n hh,prisma,api -c cyan,magenta,green \"npx hardhat node\" \"npm run db:push\" \"npm run dev\"",
    "build": "npm run build:prisma && tsc",
    "build:prisma": "prisma generate --schema=../prisma/schema.prisma",
    "start": "node dist/app.js",
    "db:push": "prisma db push --schema=../prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema=../prisma/schema.prisma",
    "db:studio": "prisma studio --schema=../prisma/schema.prisma",
    "db:seed": "tsx src/seed.ts",
    "deploy:contract": "cd ../contracts && npx hardhat run scripts/deploy.js --network localhost",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.cache"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@scure/bip32": "^2.2.0",
    "@types/bs58": "^4.0.4",
    "bip39": "^3.1.0",
    "bs58": "^6.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "ethers": "^6.13.4",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "tweetnacl": "^1.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "concurrently": "^9.1.0",
    "eslint": "^8.57.1",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
